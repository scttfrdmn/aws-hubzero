aws_region   = "us-east-1"
environment  = "test"
vpc_id       = "vpc-xxxxxxxxxxxxxxxxx"
subnet_id    = "subnet-xxxxxxxxxxxxxxxxx"
domain_name  = ""

# IMPORTANT: Restrict to your IP for security (e.g. "203.0.113.5/32")
allowed_cidr = "YOUR_IP/32"

# Email for Let's Encrypt certificate expiry notifications (recommended for staging/prod)
certbot_email = ""

# Set to true to install Docker + Solr for full HubZero Platform
install_platform = false

# Set to true to use RDS MariaDB instead of local MariaDB
use_rds        = false
rds_subnet_ids = ["subnet-aaa", "subnet-bbb"]  # at least 2 AZs, required when use_rds=true
